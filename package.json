{
  "name": "thirdoutcome",
  "version": "0.1.0",
  "private": true,
  "description": "ThirdOutcome is an Electron desktop app for natural language data queries with DuckDB and LLM-backed SQL generation.",
  "author": "Adriley",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^36.2.1",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.29.0"
  },
  "build": {
    "appId": "com.thirdoutcome.app",
    "productName": "ThirdOutcome",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
